<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:paddingTop="300px"
	android:orientation="vertical">



	<TextView
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_centerInParent="false"
		android:text="@string/app_text"
		android:id="@+id/propertiesTextView"
		android:autoSizeMaxTextSize="64px"
		android:autoSizeMinTextSize="16px"
		android:background="@android:drawable/divider_horizontal_bright"
		android:padding="8dp"
		android:gravity="center"
		android:textColor="#ff000000" 
    />


	<!-- 可放在现有根布局内的合适位置，确保根布局是垂直方向 (orientation="vertical") -->
	<LinearLayout
		android:id="@+id/button_strip"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="horizontal"
		android:padding="8dp">

		<Button
			android:id="@+id/action_study"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:text="学习" />

		<Button
			android:id="@+id/action_spendmoney"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:text="消费" />
		
		<Button
			android:id="@+id/action_doactivity"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:text="活动" />

		<Button
			android:id="@+id/action_pastime"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:text="消遣" />
	
		<Button
			android:id="@+id/action_lazy"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:text="偷懒" />
	</LinearLayout>

	<!-- 下面的区域用于动态显示“其他控件”（这里用 TextView 占位），包在 ScrollView 以支持滚动 -->
<ScrollView
		android:layout_width="match_parent"
		android:layout_height="10dp"
		android:layout_weight="1"
		android:fillViewport="true">

		<LinearLayout
			android:id="@+id/resultContainer"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">
			<Button
				android:text="testButton"
				android:layout_width="fill_parent"
				android:layout_height="wrap_content"
				android:minWidth="25px"
				android:minHeight="25px"
				android:id="@+id/testButton"
				android:visibility="invisible" />
		</LinearLayout>
	</ScrollView>
	<Button
		android:text="结束回合"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginLeft="25px"
		android:layout_marginRight="25px"
		android:layout_marginBottom="10px"
		android:id="@+id/endturnbutton"
		android:layout_below="@+id/resultContainer"/>
</LinearLayout>